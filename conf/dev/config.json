{
  "environment": "dev",
  "server": {
    "host": "localhost",
    "port": 8080,
    "debug": true
  },
  "model_server": {
    "host": "localhost",
    "port": 9009
  },
  "model": {
    "name": "SmolVLM-500M-Instruct",
